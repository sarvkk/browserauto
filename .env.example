NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL=/

# Public site URL — used for Open Graph / Messenger link previews
NEXT_PUBLIC_APP_URL=https://browserauto.sarvajit.com.np

# Clerk
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
NEON_BRANCH=main
DATABASE_URL=
DATABASE_URL_UNPOOLED=

# Trigger.dev — get from the dashboard API Keys page (DEV key starts with tr_dev_)
TRIGGER_SECRET_KEY=

NEXT_PUBLIC_LIVEBLOCKS_PUBLIC_KEY=
LIVEBLOCKS_SECRET_KEY=

BROWSERBASE_API_KEY=
# Optional — inferred from the API key when omitted
BROWSERBASE_PROJECT_ID=

SECRETS_ENCRYPTION_KEY=
# Generate with: openssl rand -hex 32

RESEND_API_KEY=
# Verified domain sender, e.g. Browserauto Playground <playground@sarvajit.com.np>
RESEND_FROM_EMAIL=

# Sentry
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_DSN=
# Build-time secret for source map upload (starts with sntrys_)
SENTRY_AUTH_TOKEN=
